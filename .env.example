# Environment Variables
# Copy this file to .env and fill in your values

# ========================================
# LLM Configuration (Multi-Provider Support)
# ========================================

# ----- Option 1: OpenAI (Default) -----
# OPENAI_API_KEY=sk-your-openai-key-here
# # OPENAI_BASE_URL is optional for OpenAI (uses default)
# LLM_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=0.1

# ----- Option 2: MiniMax (OpenAI Compatible) -----
# OPENAI_API_KEY=sk-cp-your-minimax-key-here
# OPENAI_BASE_URL=https://api.minimaxi.com/v1
# LLM_MODEL=MiniMax-M2.7-highspeed
# LLM_TEMPERATURE=1.0
# LLM_REASONING_SPLIT=true

# ----- Option 3: DeepSeek (OpenAI Compatible) -----
# OPENAI_API_KEY=sk-your-deepseek-key-here
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_TEMPERATURE=0.7

# ----- Option 4: Custom OpenAI-Compatible Provider -----
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://your-provider.com/v1
# LLM_MODEL=your-model-name
# LLM_TEMPERATURE=0.5

# ========================================
# Supported Models Reference
# ========================================

# OpenAI Models:
#   - gpt-4o-mini (fast, cheap)
#   - gpt-4o (powerful)
#   - gpt-4-turbo (balanced)

# MiniMax Models:
#   - MiniMax-M2.7 (60 TPS)
#   - MiniMax-M2.7-highspeed (100 TPS, recommended)
#   - MiniMax-M2.5 (cost-effective)
#   - MiniMax-M2.5-highspeed (fast)
#   - MiniMax-M2.1 (coding)
#   - MiniMax-M2.1-highspeed (fast coding)

# DeepSeek Models:
#   - deepseek-chat (general)
#   - deepseek-coder (coding)

# ========================================
# Advanced Configuration (Optional)
# ========================================

# LLM_REASONING_SPLIT=true    # MiniMax: separate thinking process
# LLM_TIMEOUT=30              # Request timeout in seconds
# LLM_MAX_RETRIES=3           # Max retry attempts
